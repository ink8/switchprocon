<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="14dp">

    <!-- ===== Shoulder buttons ===== -->
    <LinearLayout
        android:id="@+id/shouldersLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button android:id="@+id/btn_zl" style="@style/Shoulder" android:text="@string/btn_zl" />
        <Button android:id="@+id/btn_l" style="@style/Shoulder" android:text="@string/btn_l"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/shouldersRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btn_r" style="@style/Shoulder" android:text="@string/btn_r" />
        <Button android:id="@+id/btn_zr" style="@style/Shoulder" android:text="@string/btn_zr"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- ===== Header: status + connect ===== -->
    <TextView
        android:id="@+id/txt_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text"
        android:textSize="13sp"
        android:text="@string/status_idle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/shouldersLeft"
        app:layout_constraintEnd_toStartOf="@id/shouldersRight" />

    <LinearLayout
        android:id="@+id/topRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/txt_status"
        app:layout_constraintStart_toStartOf="@id/txt_status"
        app:layout_constraintEnd_toEndOf="@id/txt_status">

        <Button
            android:id="@+id/btn_connect"
            style="@style/Pill"
            android:text="@string/connect" />

        <Button
            android:id="@+id/btn_reset"
            style="@style/Pill"
            android:text="@string/reset"
            android:layout_marginStart="8dp" />

        <Button android:id="@+id/btn_p1" style="@style/Sys" android:text="@string/p1"
            android:layout_marginStart="10dp" android:textSize="13sp" />
        <Button android:id="@+id/btn_p2" style="@style/Sys" android:text="@string/p2"
            android:textSize="13sp" />
        <Button android:id="@+id/btn_p3" style="@style/Sys" android:text="@string/p3"
            android:textSize="13sp" />
        <Button android:id="@+id/btn_settings" style="@style/Sys" android:text="@string/settings_gear"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- ===== Left stick ===== -->
    <com.ink8.switchprocon.ui.JoystickView
        android:id="@+id/stick_left"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/shouldersLeft"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ===== D-pad ===== -->
    <GridLayout
        android:id="@+id/dpad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Space style="@style/Dcell" />
        <Button android:id="@+id/btn_up" style="@style/Dpad" android:text="@string/btn_up" />
        <Space style="@style/Dcell" />
        <Button android:id="@+id/btn_left" style="@style/Dpad" android:text="@string/btn_left" />
        <Space style="@style/Dcell" />
        <Button android:id="@+id/btn_right" style="@style/Dpad" android:text="@string/btn_right" />
        <Space style="@style/Dcell" />
        <Button android:id="@+id/btn_down" style="@style/Dpad" android:text="@string/btn_down" />
        <Space style="@style/Dcell" />
    </GridLayout>

    <!-- ===== Face buttons (A B X Y) ===== -->
    <GridLayout
        android:id="@+id/faces"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="3"
        app:layout_constraintTop_toBottomOf="@id/shouldersRight"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <Space style="@style/Fcell" />
        <Button android:id="@+id/btn_x" style="@style/Face" android:text="@string/btn_x" />
        <Space style="@style/Fcell" />
        <Button android:id="@+id/btn_y" style="@style/Face" android:text="@string/btn_y" />
        <Space style="@style/Fcell" />
        <Button android:id="@+id/btn_a" style="@style/Face" android:text="@string/btn_a" />
        <Space style="@style/Fcell" />
        <Button android:id="@+id/btn_b" style="@style/Face" android:text="@string/btn_b" />
        <Space style="@style/Fcell" />
    </GridLayout>

    <!-- ===== Right stick ===== -->
    <com.ink8.switchprocon.ui.JoystickView
        android:id="@+id/stick_right"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== Center logo ===== -->
    <LinearLayout
        android:id="@+id/logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/logo_icon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_stat_controller"
            app:tint="@color/accent"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/logo_switch"
                android:textColor="@color/text"
                android:textSize="26sp"
                android:textStyle="bold|italic"
                android:letterSpacing="0.12" />

            <TextView
                android:id="@+id/logo_procon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/logo_procon"
                android:textColor="@color/accent"
                android:textSize="26sp"
                android:textStyle="bold|italic"
                android:letterSpacing="0.12" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Center system + macro controls ===== -->
    <LinearLayout
        android:id="@+id/systemRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/topRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="18dp">

        <Button android:id="@+id/btn_minus" style="@style/Sys" android:text="@string/btn_minus" />
        <Button android:id="@+id/btn_capture" style="@style/Sys" android:text="@string/btn_capture" />
        <Button android:id="@+id/btn_home" style="@style/Sys" android:text="@string/btn_home" />
        <Button android:id="@+id/btn_plus" style="@style/Sys" android:text="@string/btn_plus" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/macroRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btn_m1" style="@style/Pill" android:text="@string/m1" />
        <Button android:id="@+id/btn_m2" style="@style/Pill" android:text="@string/m2"
            android:layout_marginStart="8dp" />
        <Button android:id="@+id/btn_m3" style="@style/Pill" android:text="@string/m3"
            android:layout_marginStart="8dp" />
        <Button android:id="@+id/btn_m4" style="@style/Pill" android:text="@string/m4"
            android:layout_marginStart="8dp" />
        <Button android:id="@+id/btn_loop" style="@style/Pill" android:text="@string/loop"
            android:layout_marginStart="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
